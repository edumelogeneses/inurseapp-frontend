{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  },
  "globals": {
    "API": "readonly",
    "showLoading": "readonly",
    "hideLoading": "readonly",
    "showToast": "readonly",
    "showAlert": "readonly",
    "formatDate": "readonly",
    "formatTokens": "readonly",
    "login": "readonly",
    "register": "readonly",
    "logout": "readonly",
    "getCurrentUser": "readonly",
    "updateProfile": "readonly",
    "changePassword": "readonly",
    "validateEmail": "readonly",
    "validatePassword": "readonly",
    "getPasswordStrength": "readonly",
    "protectPage": "readonly",
    "redirectIfAuthenticated": "readonly"
  }
}
